{
  "manifest_version": 3,
  "name": "Teams PWA Link Redirect",
  "version": "0.1.0",
  "description": "Open links in the default browser",
  "content_scripts": [
    {
      "matches": ["https://teams.microsoft.com/*", "https://teams.cloud.microsoft/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
